local ShadowLib = {}

local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local lp = Players.LocalPlayer

local SecureParent = CoreGui 
if SecureParent:FindFirstChild("ShadowHubEngine") then 
    SecureParent.ShadowHubEngine:Destroy() 
end

local function Create(class, props, parent)
    local obj = Instance.new(class)
    for i, v in pairs(props) do obj[i] = v end
    if parent then obj.Parent = parent end
    return obj
end

local function MakeDraggableSmooth(gui, handle)
    local dragging, dragInput, dragStart, startPos
    local targetPos = gui.Position

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = gui.Position; targetPos = startPos
        end
    end)
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    RunService.RenderStepped:Connect(function()
        if gui.Position ~= targetPos then gui.Position = gui.Position:Lerp(targetPos, 0.16) end
    end)
end

function ShadowLib:CreateWindow(config)
    local HubName = config.Name or "Shadow Hub"
    local ThemeColor = config.Color or Color3.fromRGB(0, 150, 255)
    
    local gui = Create("ScreenGui", {Name = "ShadowHubEngine", DisplayOrder = 9999999, ResetOnSpawn = false, Parent = SecureParent})
    
    local ToggleBtn = Create("ImageButton", {
        Size = UDim2.new(0, 50, 0, 50), Position = UDim2.new(0, 15, 0.5, -25),
        Image = "rbxthumb://type=AvatarHeadShot&id="..lp.UserId.."&w=150&h=150",
        BackgroundColor3 = Color3.fromRGB(20, 25, 35), Active = true, ZIndex = 100, Parent = gui
    })
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, ToggleBtn)
    Create("UIStroke", {Color = ThemeColor, Thickness = 2}, ToggleBtn)
    MakeDraggableSmooth(ToggleBtn, ToggleBtn)

    local MainFrame = Create("Frame", {
        Size = UDim2.new(0, 600, 0, 400), Position = UDim2.new(0.5, -300, 0.5, -200),
        BackgroundColor3 = Color3.fromRGB(15, 20, 30), Active = true, Visible = false, Parent = gui
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, MainFrame)
    Create("UIStroke", {Color = ThemeColor, Thickness = 2}, MainFrame)
    
    local TopBar = Create("Frame", {Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1, Active = true, Parent = MainFrame})
    MakeDraggableSmooth(MainFrame, TopBar)
    ToggleBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

    local Sidebar = Create("Frame", {Size = UDim2.new(0, 160, 1, 0), BackgroundColor3 = Color3.fromRGB(10, 15, 25), Parent = MainFrame})
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, Sidebar)

    local Profile = Create("Frame", {Size = UDim2.new(1, 0, 0, 100), BackgroundTransparency = 1, Parent = Sidebar})
    local Avatar = Create("ImageLabel", {Size = UDim2.new(0, 45, 0, 45), Position = UDim2.new(0.5, -22.5, 0, 15), Image = "rbxthumb://type=AvatarHeadShot&id="..lp.UserId.."&w=150&h=150", BackgroundColor3 = Color3.fromRGB(30, 30, 40), Parent = Profile})
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, Avatar)
    Create("TextLabel", {Size = UDim2.new(1, 0, 0, 20), Position = UDim2.new(0, 0, 0, 65), Text = lp.Name, TextColor3 = Color3.new(1,1,1), Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Parent = Profile})
    
    local rig = (lp.Character and lp.Character:FindFirstChild("Humanoid") and lp.Character.Humanoid.RigType.Name) or "R15"
    Create("TextLabel", {Size = UDim2.new(1, 0, 0, 15), Position = UDim2.new(0, 0, 0, 85), Text = rig .. " | " .. HubName, TextColor3 = Color3.fromRGB(120, 120, 130), TextSize = 10, Font = Enum.Font.Gotham, BackgroundTransparency = 1, Parent = Profile})

    local TabContainer = Create("ScrollingFrame", {Size = UDim2.new(1, 0, 1, -110), Position = UDim2.new(0, 0, 0, 110), BackgroundTransparency = 1, ScrollBarThickness = 0, Parent = Sidebar})
    Create("UIListLayout", {Padding = UDim.new(0, 5), HorizontalAlignment = Enum.HorizontalAlignment.Center}, TabContainer)

    local PageContainer = Create("Frame", {Size = UDim2.new(1, -170, 1, -20), Position = UDim2.new(0, 165, 0, 10), BackgroundTransparency = 1, Parent = MainFrame})

    local Window = {}
    function Window:CreateTab(name)
        local TabBtn = Create("TextButton", {Size = UDim2.new(0.9, 0, 0, 32), Text = name, BackgroundColor3 = Color3.fromRGB(25, 30, 40), TextColor3 = Color3.fromRGB(200, 200, 200), Font = Enum.Font.GothamSemibold, Parent = TabContainer})
        Create("UICorner", {CornerRadius = UDim.new(0, 6)}, TabBtn)
        
        local Page = Create("ScrollingFrame", {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, ScrollBarThickness = 2, AutomaticCanvasSize = Enum.AutomaticSize.Y, Visible = false, Parent = PageContainer})
        Create("UIListLayout", {Padding = UDim.new(0, 8)}, Page)

        TabBtn.MouseButton1Click:Connect(function()
            for _, p in pairs(PageContainer:GetChildren()) do if p:IsA("ScrollingFrame") then p.Visible = false end end
            for _, b in pairs(TabContainer:GetChildren()) do if b:IsA("TextButton") then b.TextColor3 = Color3.fromRGB(200, 200, 200) end end
            Page.Visible = true; TabBtn.TextColor3 = ThemeColor
        end)

        local Elements = {}
        
        function Elements:CreateButton(cfg)
            local btn = Create("TextButton", {Size = UDim2.new(1, -10, 0, 35), Text = "  " .. cfg.Name, BackgroundColor3 = Color3.fromRGB(25, 30, 40), TextColor3 = Color3.new(1,1,1), Font = Enum.Font.GothamSemibold, TextXAlignment = Enum.TextXAlignment.Left, Parent = Page})
            Create("UICorner", {CornerRadius = UDim.new(0, 6)}, btn)
            btn.MouseButton1Click:Connect(function() pcall(cfg.Callback) end)
        end

        function Elements:CreateToggle(cfg)
            local tgl = Create("TextButton", {Size = UDim2.new(1, -10, 0, 35), Text = "  " .. cfg.Name, BackgroundColor3 = Color3.fromRGB(25, 30, 40), TextColor3 = Color3.new(1,1,1), Font = Enum.Font.GothamSemibold, TextXAlignment = Enum.TextXAlignment.Left, Parent = Page})
            Create("UICorner", {CornerRadius = UDim.new(0, 6)}, tgl)
            local box = Create("Frame", {Size = UDim2.new(0, 20, 0, 20), Position = UDim2.new(1, -30, 0.5, -10), BackgroundColor3 = Color3.fromRGB(40, 45, 55), Parent = tgl})
            Create("UICorner", {CornerRadius = UDim.new(0, 4)}, box)
            
            local state = cfg.CurrentValue or false
            if state then box.BackgroundColor3 = ThemeColor end
            
            tgl.MouseButton1Click:Connect(function()
                state = not state
                TweenService:Create(box, TweenInfo.new(0.2), {BackgroundColor3 = state and ThemeColor or Color3.fromRGB(40, 45, 55)}):Play()
                pcall(function() cfg.Callback(state) end)
            end)
        end

        function Elements:CreateDropdown(cfg)
            local dropFrame = Create("Frame", {Size = UDim2.new(1, -10, 0, 35), BackgroundColor3 = Color3.fromRGB(25, 30, 40), ClipsDescendants = true, Parent = Page})
            Create("UICorner", {CornerRadius = UDim.new(0, 6)}, dropFrame)
            local dropBtn = Create("TextButton", {Size = UDim2.new(1, 0, 0, 35), Text = "  " .. cfg.Name, TextColor3 = Color3.new(1,1,1), Font = Enum.Font.GothamSemibold, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Parent = dropFrame})
            local icon = Create("TextLabel", {Size = UDim2.new(0, 35, 0, 35), Position = UDim2.new(1, -35, 0, 0), Text = "▼", TextColor3 = ThemeColor, BackgroundTransparency = 1, Parent = dropBtn})
            
            local listFrame = Create("ScrollingFrame", {Size = UDim2.new(1, -10, 0, 100), Position = UDim2.new(0, 5, 0, 35), BackgroundTransparency = 1, ScrollBarThickness = 2, Parent = dropFrame})
            local listLayout = Create("UIListLayout", {Padding = UDim.new(0, 3)}, listFrame)
            
            local isOpen = false
            local function Refresh(options)
                for _, v in pairs(listFrame:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
                for _, opt in pairs(options) do
                    local optBtn = Create("TextButton", {Size = UDim2.new(1, 0, 0, 25), Text = opt, BackgroundColor3 = Color3.fromRGB(35, 40, 55), TextColor3 = Color3.new(1,1,1), Font = Enum.Font.Gotham, Parent = listFrame})
                    Create("UICorner", {CornerRadius = UDim.new(0, 4)}, optBtn)
                    optBtn.MouseButton1Click:Connect(function()
                        dropBtn.Text = "  " .. cfg.Name .. ": " .. opt
                        pcall(function() cfg.Callback(opt) end)
                        isOpen = false; TweenService:Create(dropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, -10, 0, 35)}):Play(); icon.Rotation = 0
                    end)
                end
            end
            Refresh(cfg.Options)

            dropBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                local targetSize = isOpen and UDim2.new(1, -10, 0, 35 + math.clamp(#cfg.Options * 28, 28, 110)) or UDim2.new(1, -10, 0, 35)
                TweenService:Create(dropFrame, TweenInfo.new(0.2), {Size = targetSize}):Play()
                TweenService:Create(icon, TweenInfo.new(0.2), {Rotation = isOpen and 180 or 0}):Play()
            end)

            return {Refresh = Refresh}
        end

        return Elements
    end
    return Window
end

return ShadowLib
